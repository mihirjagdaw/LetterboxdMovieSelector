@page "/movie"
@rendermode InteractiveServer
@using MovieSelector.Shared.Models
@using MovieSelector.Web.Services
@inject MovieApiClient movieApiClient

@if (movie == null)
{
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="container d-flex align-items-center min-vh-100">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <h1>Welcome to Movie Selector!</h1>
                <div class="card p-4 mt-5">
                    <h2>Here's what I think you should watch!</h2>
                    <div class="d-grid mt-3">
                        <p>@movie.Name</p>
                        <p>@movie.ReleaseYear</p>
                        <button class="btn btn-primary mt-3" @onclick="randomMovie">Pick another movie</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@code {

    private Movie? movie;

    protected override async Task OnInitializedAsync()
    {
        await randomMovie();
    }

    private async Task randomMovie()
    {
        movie = null;
        movie = await movieApiClient.getRandomMovieAsync();
    }

}
