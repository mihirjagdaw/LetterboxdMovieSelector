@page "/"
@rendermode InteractiveServer
@using MovieSelector.Web.Services
@inject MovieApiClient movieApiClient
@inject NavigationManager navigation

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="col-md-6">
            <h1 class="text-center">Welcome to Movie Selector!</h1>
            <div class="upload-card">
                <h2 class="text-center">Upload your watchlist here!</h2>
                <label class="file-upload-label mt-3">
                    <span>📁 Choose CSV File</span>
                    <InputFile OnChange="HandleFileUpload" accept=".csv" class="file-input-hidden" />
                </label>
            </div>
        </div>
    </div>
}


@code {
    private bool isLoading = false;

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            isLoading = true;
            try
            {
                await movieApiClient.UploadWatchlistAsync(file);
                navigation.NavigateTo("/movie");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Upload failed: {ex.Message}");
                isLoading = false;
            }
        }
    }
}

<style>
    .upload-card {
        background: #1a1a2e;
        border: 1px solid rgb(0, 172, 28);
        border-radius: 12px;
        padding: 2rem;
        color: #eaeaea;
    }

    .file-upload-label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        cursor: pointer;
        background: rgb(0, 172, 28);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        letter-spacing: 0.05em;
        transition: background 0.2s ease, transform 0.1s ease;
        width: 100%;
    }

        .file-upload-label:hover {
            background: rgb(0, 172, 28)
            transform: translateY(-1px);
        }

    .file-input-hidden {
        display: none;
    }
</style>